{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx",
        "lib": [
            "ESNext"
        ],
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "types": [
            "bun"
        ]
    }
}
